---
import BaseLayout from "../layouts/BaseLayout.astro";
import {getEntry} from 'astro:content';

const entry = await getEntry('legal', '特定商取引法に基づく表記');
if (!entry) return Astro.redirect('/404');

const {Content} = await entry.render();
---
<BaseLayout title="特定商取引法に基づく表記">
    <main class="w-full max-w-2xl mx-auto px-4 py-4 flex-1 flex flex-col items-center">
        <article class="prose dark:prose-invert prose-sm text-left">
            <Content/>
        </article>
    </main>
</BaseLayout>
